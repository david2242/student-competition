# ASP.NET Core environment (Development / Production)
ASPNETCORE_ENVIRONMENT=Development

# PostgreSQL connection settings
SQL_SERVER_HOST=localhost
SQL_SERVER_USERNAME=postgres
SQL_SERVER_PASSWORD=          # Required: set a strong password
SQL_DATABASE_NAME=student_competition
SQL_SERVER_PORT=5432

# Enable Swagger UI (True / False) — should be False in production
SWAGGER=True

# Default admin account password (used only on first DB seed)
DEFAULT_ADMIN_PASSWORD=       # Required: set a strong password
